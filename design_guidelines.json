{
  "brand_identity": {
    "name": "Glamira",
    "tone": "Ethereal, Luxurious, Timeless, Sophisticated",
    "theme_mode": "Light Luxury (Primary)",
    "core_values": ["Exquisite Craftsmanship", "Timeless Elegance", "Personalized Luxury"]
  },
  "design_system": {
    "colors": {
      "primary": "#1A1A1A",
      "secondary": "#D4AF37",
      "background_main": "#FFFFFF",
      "background_alt": "#F9F9F9",
      "text_primary": "#111111",
      "text_secondary": "#666666",
      "accent_error": "#D32F2F",
      "accent_success": "#388E3C",
      "border_subtle": "#E5E5E5"
    },
    "typography": {
      "font_family_heading": "'Playfair Display', serif",
      "font_family_body": "'Montserrat', sans-serif",
      "weights": {
        "light": 300,
        "regular": 400,
        "medium": 500,
        "bold": 700
      },
      "imports": [
        "@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap');"
      ]
    },
    "spacing": {
      "base": "1rem",
      "section_padding": "5rem 0",
      "container_padding": "2rem"
    },
    "ui_elements": {
      "border_radius": "0px",
      "shadow_card": "0 10px 30px rgba(0,0,0,0.05)",
      "shadow_hover": "0 20px 40px rgba(0,0,0,0.08)",
      "transition_standard": "all 0.4s cubic-bezier(0.16, 1, 0.3, 1)"
    }
  },
  "components": {
    "ProductCard": {
      "concept": "The Gallery Frame",
      "style": {
        "border": "none",
        "background": "transparent",
        "padding": "0",
        "shadow": "none"
      },
      "image_container": {
        "aspect_ratio": "4/5",
        "background": "#F4F4F4",
        "behavior": "overflow-hidden relative group"
      },
      "hover_effect": "Image distinct zoom (scale 1.05), Quick Add button slides up from bottom",
      "typography": {
        "title": "font-playfair text-lg mt-3 text-center text-primary tracking-wide",
        "price": "font-montserrat text-sm text-secondary font-medium text-center"
      }
    },
    "Buttons": {
      "primary": {
        "background": "#1A1A1A",
        "text": "#FFFFFF",
        "border": "1px solid #1A1A1A",
        "hover_bg": "#FFFFFF",
        "hover_text": "#1A1A1A",
        "shape": "sharp (0px radius) or slightly rounded (2px)",
        "transform": "uppercase tracking-widest text-xs py-3 px-8"
      },
      "secondary": {
        "background": "transparent",
        "text": "#1A1A1A",
        "border": "1px solid #E5E5E5",
        "hover_border": "#1A1A1A"
      }
    },
    "Navbar": {
      "style": "Minimalist, sticky top",
      "background": "white/90 backdrop-blur-md",
      "border_bottom": "1px solid rgba(0,0,0,0.05)",
      "links": "uppercase text-xs tracking-widest hover:text-[#D4AF37]"
    }
  },
