  "implementation_guide": {
    "scss_setup": {
      "instructions": "Update App.scss to override Bootstrap variables BEFORE importing bootstrap if possible, or use !important for key luxury overrides.",
      "critical_overrides": [
        ".card { border: none !important; background: transparent !important; }",
        ".btn-primary { background-color: #1A1A1A; border-color: #1A1A1A; border-radius: 0; }",
        ".btn-primary:hover { background-color: #333; border-color: #333; }",
        "a { text-decoration: none; color: inherit; }"
      ]
    },
    "component_instructions": {
      "ProductCard": "Create a new component 'ProductCard.js'. Do not use the default React-Bootstrap Card component for the visual part if it limits customization. Use raw divs with bootstrap utility classes + custom SCSS.",
      "Swiper": "Ensure Swiper pagination dots are small and gold (#D4AF37). Navigation arrows should be thin and minimal."
    }
  },
  "UNIVERSAL_GUIDELINES": {
    "general": [
      "Avoid 'Bootstrap Look': No default blue buttons, no rounded grey borders.",
      "Use ample whitespace: Increase margins between sections (py-5 is minimum, aim for py-6 or py-7 equivalent).",
      "Typography Hierarchy: Headings (Playfair) should be significantly larger than body text.",
      "Images: Must use object-fit: cover to ensure consistency in grids.",
      "Interactive: Add hover states to everything. Buttons should fill/invert. Images should zoom."
    ]
  }
}